### https://raw.github.com/github/gitignore/master/Rust.gitignore

# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Admin UI dependencies and generated assets
admin-ui/node_modules/
admin-ui/dist/*
!admin-ui/dist/.gitkeep
admin-ui/*.tsbuildinfo
admin-ui/playwright-report/
admin-ui/test-results/

# These are backup files generated by rustfmt
**/*.rs.bk
*.pdb

# eBPF build artifacts
*.bpf.o
*.o
.output/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Local cargo config (machine-specific settings)
.cargo/

# Testing/debugging
*.log
*.profraw
*.profdata
xlb.yaml

# Documentation build output
docs/site/
docs/schema.json
