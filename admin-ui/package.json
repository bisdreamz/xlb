    "vue": "3.5.40",
    "vue-router": "5.2.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@vitejs/plugin-vue": "6.0.2",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vue-tsc": "3.1.4"
  }
}
